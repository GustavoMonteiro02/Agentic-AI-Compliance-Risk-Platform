DATABASE_URL=sqlite:///./ai_governance.db

# LLM test mode. Copy this file to .env and set OPENAI_API_KEY.
AI_GENERATION_MODE=llm
LLM_PROVIDER=openai
OPENAI_API_KEY=replace-with-your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_SECONDS=60
OPENAI_MAX_RETRIES=2
OPENAI_MAX_TOKENS=2000

# Optional usage estimate values. Leave 0 if you only want token counts.
LLM_PROMPT_COST_PER_1K_TOKENS=0
LLM_COMPLETION_COST_PER_1K_TOKENS=0

# Local testing keeps platform auth disabled so Streamlit/React can call the API without another key.
AUTH_MODE=disabled
DEFAULT_USER_ROLE=admin
DEFAULT_TENANT_ID=default

VECTOR_DB=local
EMBEDDING_PROVIDER=local_hash

SECURITY_HEADERS_ENABLED=true
SECURITY_HSTS_ENABLED=false
MAX_REQUEST_BODY_BYTES=1048576
API_RATE_LIMIT_PER_MINUTE=0

API_BASE_URL=http://127.0.0.1:8000
PLATFORM_USER=streamlit-user
PLATFORM_USER_ROLE=admin
PLATFORM_TENANT_ID=default

MCP_TRANSPORT=stdio
