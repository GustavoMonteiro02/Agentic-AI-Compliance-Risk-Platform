# AI Governance & Compliance Platform configuration template.
# Copy this file to .env for local development or production-like Docker testing.
# Keep real keys only in .env. Do not commit .env.

# ---------------------------------------------------------------------------
# Runtime profile
# ---------------------------------------------------------------------------
# Local deterministic default: no external LLM calls.
# For production-like testing with your OpenAI key, use: AI_GENERATION_MODE=llm
AI_GENERATION_MODE=deterministic
LLM_PROVIDER=openai

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# Local Python/dev default:
DATABASE_URL=sqlite:///./ai_governance.db
# Docker production-like stack uses:
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@postgres:5432/ai_governance

# ---------------------------------------------------------------------------
# OpenAI / OpenAI-compatible LLM
# ---------------------------------------------------------------------------
# Required only when AI_GENERATION_MODE=llm/openai or EMBEDDING_PROVIDER=openai.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_SECONDS=60
OPENAI_MAX_RETRIES=2
OPENAI_MAX_TOKENS=2000

# Optional usage-cost estimates shown by /assessments/llm-usage.
LLM_PROMPT_COST_PER_1K_TOKENS=0
LLM_COMPLETION_COST_PER_1K_TOKENS=0

# ---------------------------------------------------------------------------
# Anthropic alternative provider
# ---------------------------------------------------------------------------
# Required only if LLM_PROVIDER=anthropic.
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# ---------------------------------------------------------------------------
# LangSmith observability/evaluation upload
# ---------------------------------------------------------------------------
# Optional. Local evaluation still works without this key.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_API_URL=https://api.smith.langchain.com
LANGSMITH_PROJECT=ai-governance-compliance-platform

# ---------------------------------------------------------------------------
# RAG / vector search
# ---------------------------------------------------------------------------
# Local deterministic default:
VECTOR_DB=local
EMBEDDING_PROVIDER=local_hash
EMBEDDING_DIMENSIONS=128

# Production-like local Docker:
# VECTOR_DB=qdrant
# EMBEDDING_PROVIDER=openai
# EMBEDDING_DIMENSIONS=1536
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=ai_governance_requirements
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Optional managed vector store alternative. Required only if VECTOR_DB=pinecone.
PINECONE_API_KEY=
PINECONE_INDEX_HOST=
PINECONE_NAMESPACE=ai-governance-requirements

# ---------------------------------------------------------------------------
# API auth, roles, tenancy
# ---------------------------------------------------------------------------
# Local deterministic default:
AUTH_MODE=disabled
PLATFORM_API_KEY=
PLATFORM_API_KEY_SHA256=
DEFAULT_USER_ROLE=admin
DEFAULT_TENANT_ID=default

# Production-like testing:
# AUTH_MODE=api_key
# Generate PLATFORM_API_KEY with: openssl rand -hex 32
# Set VITE_PLATFORM_API_KEY to the same value for the React UI.

# ---------------------------------------------------------------------------
# API security and browser access
# ---------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=
SECURITY_HEADERS_ENABLED=true
SECURITY_HSTS_ENABLED=false
MAX_REQUEST_BODY_BYTES=1048576
API_RATE_LIMIT_PER_MINUTE=0

# ---------------------------------------------------------------------------
# Review workflow and notifications
# ---------------------------------------------------------------------------
REVIEW_SLA_HOURS=48
REVIEW_MISSING_EVIDENCE_ESCALATION_THRESHOLD=3
REVIEW_HIGH_RISK_CRITICAL_GAP_ESCALATION=true
NOTIFICATION_DELIVERY_MODE=manual
NOTIFICATION_WEBHOOK_URL=
NOTIFICATION_WEBHOOK_TIMEOUT_SECONDS=10

# ---------------------------------------------------------------------------
# Streamlit UI client
# ---------------------------------------------------------------------------
API_BASE_URL=http://127.0.0.1:8000
PLATFORM_USER=streamlit-user
PLATFORM_USER_ROLE=admin
PLATFORM_TENANT_ID=default

# ---------------------------------------------------------------------------
# React/Vite UI client
# ---------------------------------------------------------------------------
VITE_API_BASE_URL=http://127.0.0.1:8000
VITE_PLATFORM_API_KEY=
VITE_PLATFORM_USER=react-user
VITE_PLATFORM_USER_ROLE=admin
VITE_PLATFORM_TENANT_ID=default

# ---------------------------------------------------------------------------
# MCP service
# ---------------------------------------------------------------------------
MCP_SERVER_NAME=ai-governance-compliance
MCP_TRANSPORT=stdio
MCP_HOST=0.0.0.0
MCP_PORT=9000
