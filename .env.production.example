# Copy to .env.production and fill the placeholders.

# Database and vector store used by docker-compose.production.yml
DATABASE_URL=postgresql+psycopg2://postgres:postgres@postgres:5432/ai_governance
VECTOR_DB=qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=ai_governance_requirements

# Live LLM refinement
AI_GENERATION_MODE=llm
LLM_PROVIDER=openai
OPENAI_API_KEY=replace-with-your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_SECONDS=60
OPENAI_MAX_RETRIES=2
OPENAI_MAX_TOKENS=2000

# Use OpenAI embeddings if you want Qdrant to behave closer to production.
# Use local_hash if you want lower-cost deterministic testing.
EMBEDDING_PROVIDER=openai
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# Optional cost estimates for /assessments/llm-usage
LLM_PROMPT_COST_PER_1K_TOKENS=0
LLM_COMPLETION_COST_PER_1K_TOKENS=0

# Platform authentication
AUTH_MODE=api_key
PLATFORM_API_KEY=change-me
PLATFORM_API_KEY_SHA256=
DEFAULT_USER_ROLE=admin
DEFAULT_TENANT_ID=prod-test

# API hardening
CORS_ALLOWED_ORIGINS=http://127.0.0.1:8501,http://127.0.0.1:5173
SECURITY_HEADERS_ENABLED=true
SECURITY_HSTS_ENABLED=false
MAX_REQUEST_BODY_BYTES=1048576
API_RATE_LIMIT_PER_MINUTE=120

# Review/notification operations
REVIEW_SLA_HOURS=48
REVIEW_MISSING_EVIDENCE_ESCALATION_THRESHOLD=3
REVIEW_HIGH_RISK_CRITICAL_GAP_ESCALATION=true
NOTIFICATION_DELIVERY_MODE=manual
NOTIFICATION_WEBHOOK_URL=
NOTIFICATION_WEBHOOK_TIMEOUT_SECONDS=10

# Optional providers/integrations
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_API_URL=https://api.smith.langchain.com
LANGSMITH_PROJECT=ai-governance-compliance-platform
PINECONE_API_KEY=
PINECONE_INDEX_HOST=
PINECONE_NAMESPACE=ai-governance-requirements

# Streamlit UI container
API_BASE_URL=http://api:8000
PLATFORM_USER=production-tester
PLATFORM_USER_ROLE=admin
PLATFORM_TENANT_ID=prod-test

# React/Vite command center container
VITE_API_BASE_URL=http://127.0.0.1:8000
VITE_PLATFORM_API_KEY=change-me
VITE_PLATFORM_USER=production-tester
VITE_PLATFORM_USER_ROLE=admin
VITE_PLATFORM_TENANT_ID=prod-test

# MCP service
MCP_SERVER_NAME=ai-governance-compliance
MCP_TRANSPORT=streamable-http
MCP_HOST=0.0.0.0
MCP_PORT=9000
